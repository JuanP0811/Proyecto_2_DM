import time
import gc
from datetime import datetime

import pyarrow.dataset as ds
from sqlalchemy import create_engine, text
from mage_ai.data_preparation.shared.secrets import get_secret_value

if 'data_exporter' not in globals():
    from mage_ai.data_preparation.decorators import data_exporter


def pg_engine():
    host = get_secret_value("POSTGRES_HOST")
    port = get_secret_value("POSTGRES_PORT") or "5432"
    db   = get_secret_value("POSTGRES_DB")
    user = get_secret_value("POSTGRES_USER")
    pwd  = get_secret_value("POSTGRES_PASSWORD")
    return create_engine(f"postgresql+psycopg2://{user}:{pwd}@{host}:{port}/{db}")


@data_exporter
def export_data(data, *args, **kwargs):

    # --- unwrap por si Mage envuelve el output ---
    jobs = data
    if isinstance(data, dict):
        for v in data.values():
            if isinstance(v, list):
                jobs = v
                break

    if not isinstance(jobs, list) or not jobs:
        raise ValueError(f"Se esperaba lista de jobs. Llegó: {type(data)}")

    engine = pg_engine()

    # Parámetros que controlan memoria
    batch_size = int(kwargs.get("batch_size", 50_000))   # lectura parquet
    chunksize  = int(kwargs.get("chunksize", 10_000))    # escritura SQL
    log_every_batches = int(kwargs.get("log_every_batches", 5))  # prints cada N batches

    total = len(jobs)
    ok = 0
    missing = 0
    failed = 0

    print("=" * 100, flush=True)
    print("[START] Exporter STREAMING (Yellow + Green) -> bronze.trips_raw", flush=True)
    print(f"[CONFIG] jobs={total} | batch_size(read)={batch_size} | chunksize(sql)={chunksize}", flush=True)
    print(f"[CONFIG] log_every_batches={log_every_batches}", flush=True)
    print("=" * 100, flush=True)

    t_all = time.time()

    for i, job in enumerate(jobs, start=1):
        ym = job["year_month"]
        st = job["service_type"]
        url = job["url_parquet"]

        print("\n" + "-" * 100, flush=True)
        print(f"[JOB {i}/{total}] START | service={st} | month={ym}", flush=True)
        print(f"[JOB {i}] URL={url}", flush=True)

        # 1) Crear dataset parquet (no carga todo)
        t_dataset = time.time()
        try:
            dataset = ds.dataset(url, format="parquet")
            print(f"[JOB {i}] dataset OK | time={time.time() - t_dataset:.2f}s", flush=True)
        except Exception as e:
            missing += 1
            print(f"[JOB {i}] ERROR dataset/parquet | {type(e).__name__}: {e}", flush=True)
            continue

        total_rows = 0
        batch_idx = 0
        t_job = time.time()

        try:
            with engine.begin() as conn:
                # 2) Idempotencia (borra ese mes/servicio)
                t_del = time.time()
                conn.execute(
                    text("DELETE FROM bronze.trips_raw WHERE source_month=:ym AND service_type=:st"),
                    {"ym": ym, "st": st}
                )
                print(f"[JOB {i}] DELETE OK | time={time.time() - t_del:.2f}s", flush=True)

                # 3) Lectura streaming por batches
                t_stream = time.time()
                for batch in dataset.to_batches(batch_size=batch_size):
                    batch_idx += 1

                    # convertir solo este batch a pandas
                    df_chunk = batch.to_pandas()

                    # metadata por chunk
                    df_chunk["ingest_ts"] = datetime.utcnow()
                    df_chunk["source_month"] = ym
                    df_chunk["service_type"] = st

                    # insertar por chunks en SQL
                    df_chunk.to_sql(
                        name="trips_raw",
                        con=conn,
                        schema="bronze",
                        if_exists="append",
                        index=False,
                        method="multi",
                        chunksize=chunksize,
                    )

                    total_rows += len(df_chunk)

                    # liberar memoria del chunk
                    del df_chunk
                    gc.collect()

                    # prints de progreso cada N batches
                    if log_every_batches > 0 and (batch_idx % log_every_batches == 0):
                        elapsed = time.time() - t_stream
                        print(
                            f"[JOB {i}] PROGRESS | batches={batch_idx} | rows_loaded={total_rows} | "
                            f"elapsed={elapsed:.1f}s",
                            flush=True
                        )

            ok += 1
            print(
                f"[JOB {i}] DONE OK | batches={batch_idx} | rows_loaded={total_rows} | "
                f"time={time.time() - t_job:.2f}s",
                flush=True
            )

        except Exception as e:
            failed += 1
            print(f"[JOB {i}] FAILED | {type(e).__name__}: {e}", flush=True)

        finally:
            # liberar dataset
            try:
                del dataset
            except Exception:
                pass
            gc.collect()

        print(f"[GLOBAL PROGRESS] ok={ok} | missing={missing} | failed={failed}", flush=True)

    total_s = time.time() - t_all
    print("\n" + "=" * 100, flush=True)
    print("[DONE] INGEST FINALIZADO (STREAMING)", flush=True)
    print(f"[SUMMARY] ok={ok} | missing={missing} | failed={failed} | total={total}", flush=True)
    print(f"[SUMMARY] total_time={(total_s/60):.2f} min", flush=True)
    print("=" * 100, flush=True)

    return {"total": total, "ok": ok, "missing": missing, "failed": failed}

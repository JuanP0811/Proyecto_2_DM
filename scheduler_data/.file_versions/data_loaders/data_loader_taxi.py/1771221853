if 'data_loader' not in globals():
    from mage_ai.data_preparation.decorators import data_loader
if 'test' not in globals():
    from mage_ai.data_preparation.decorators import test


@data_loader
def load_data(*args, **kwargs):
    years = [2022, 2023, 2024, 2025]

    jobs = []
    for y in years:
        for m in range(1, 13):
            jobs.append({
                "year": y,
                "month": m,
                "year_month": f"{y}-{m:02d}",
                "service_type": "yellow",
            })

    print("=" * 70)
    print("[START] Generando jobs para ingestión Yellow 2022-2025")
    print(f"[INFO] Total jobs: {len(jobs)} (debe ser 48)")
    print("[INFO] Ejemplo job:", jobs[0])
    print("=" * 70)

    return jobs


@test
def test_output(output, *args) -> None:
    assert output is not None, "El output es undefined"
    assert isinstance(output, list), "Se esperaba una lista de jobs"
    assert len(output) == 48, f"Se esperaban 48 jobs, llegaron {len(output)}"
    assert all(("year" in j and "month" in j and "year_month" in j and "service_type" in j) for j in output), \
        "Faltan llaves en uno o más jobs"

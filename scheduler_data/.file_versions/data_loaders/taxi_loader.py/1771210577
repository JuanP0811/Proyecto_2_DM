if 'data_loader' not in globals():
    from mage_ai.data_preparation.decorators import data_loader
if 'test' not in globals():
    from mage_ai.data_preparation.decorators import test

import os
import pandas as pd
from datetime import datetime, timezone


def _get_required_kwarg(kwargs: dict, key: str) -> str:
    """
    Read a required kwarg in a friendly way.
    """
    value = kwargs.get(key)
    if value is None or str(value).strip() == "":
        raise ValueError(
            f"Missing required kwarg '{key}'. "
            f"Pass it via pipeline runtime variables, e.g. {{'{key}': '...'}}"
        )
    return str(value).strip()


def _normalize_month(month: str) -> str:
    """
    Accepts '1' or '01' -> returns '01'
    """
    m = int(month)
    if m < 1 or m > 12:
        raise ValueError(f"Invalid month: {month}. Must be 1..12")
    return f"{m:02d}"


def _build_tlc_parquet_url(service_type: str, year: str, month_2d: str) -> str:
    """
    NYC TLC parquet files live in AWS (cloudfront) for recent years.
    Example:
      https://d37ci6vzurychx.cloudfront.net/trip-data/yellow_tripdata_2024-01.parquet
    """
    st = service_type.lower().strip()
    if st not in {"yellow", "green"}:
        raise ValueError("service_type must be 'yellow' or 'green'")
    return f"https://d37ci6vzurychx.cloudfront.net/trip-data/{st}_tripdata_{year}-{month_2d}.parquet"


@data_loader
def load_data(*args, **kwargs):
    """
    Loads ONE MONTH of NYC TLC tripdata (yellow/green) into a pandas DataFrame.

    Expected runtime kwargs:
      - year: "2024"
      - month: "1" or "01"
      - service_type: "yellow" or "green"

    Returns:
      pandas.DataFrame with extra metadata columns:
        - ingest_ts (UTC timestamp)
        - source_month (YYYY-MM)
        - service_type (yellow/green)
    """
    # Defaults so you can run the block without runtime variables
    year = str(kwargs.get("year", "2024")).strip()
    month = _normalize_month(str(kwargs.get("month", "01")).strip())
    service_type = str(kwargs.get("service_type", "yellow")).strip().lower()


    source_month = f"{year}-{month}"
    url = _build_tlc_parquet_url(service_type, year, month)

    # Read parquet directly from URL (pyarrow is typically available in Mage images)
    df = pd.read_parquet(url, engine="pyarrow")

    # Add mandatory ingestion metadata (per-row)
    ingest_ts = datetime.now(timezone.utc)
    df["ingest_ts"] = ingest_ts
    df["source_month"] = source_month
    df["service_type"] = service_type

    return df


@test
def test_output(output, *args) -> None:
    assert output is not None, "The output is undefined"
    # Basic sanity checks
    assert hasattr(output, "shape"), "Output is not a DataFrame-like object"
    assert "ingest_ts" in output.columns, "Missing ingest_ts"
    assert "source_month" in output.columns, "Missing source_month"
    assert "service_type" in output.columns, "Missing service_type"
    assert len(output) > 0, "Loaded 0 rows (check year/month/service_type or URL availability)"


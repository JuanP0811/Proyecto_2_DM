om' not in globals():\n    from mage_ai.data_preparation.decorators import custom\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\nimport requests\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    \"\"\"\n    args: The output from any upstream parent blocks (if applicable)\n\n    Returns:\n        dict: response JSON from Mage API trigger\n    \"\"\"\n    # Endpoint del trigger API (si te falla por conexi\u00f3n en Docker, cambia localhost -> mage o el nombre del servicio)\n    TRIGGER_URL = \"http://localhost:6789/api/pipeline_schedules/3/pipeline_runs/1521dad314cb4e6093b6dc76766aacd3\"\n\n    payload = {\n        \"pipeline_run\": {\n            \"variables\": {\n                \"triggered_by\": \"dbt_build_silver\"\n            }\n        }\n    }\n\n    print(f\"Calling Mage API trigger: {TRIGGER_URL}\")\n    r = requests.post(TRIGGER_URL, json=payload, timeout=30)\n    r.raise_for_status()\n\n    resp = r.json()\n    print(\"Triggered OK:\", resp)\n    return resp\n\n", "file_path": "/home/src/custom/trigger_dbt_gold.py", "language": "python", "type": "custom", "uuid": "trigger_dbt_gold"}, "/home/src/dbts/silver_transformations/models/gold/dim_service_type.sql:dbt:sql:home/src/dbts/silver transformations/models/gold/dim service type": {"content": "{{ config(materialized='table') }}\n\nselect distinct\n    service_type as service_type_key,\n    service_type as service_type_name\nfrom silver.trips_silver_clean\nwhere service_type is not null\norder by service_type", "file_path": "/home/src/dbts/silver_transformations/models/gold/dim_service_type.sql", "language": "sql", "type": "dbt", "uuid": "dbts/silver_transformations/models/gold/dim_service_type"}, "/home/src/dbts/silver_transformations/models/gold/dim_payment_type.sql:dbt:sql:home/src/dbts/silver transformations/models/gold/dim payment type": {"content": "{{ config(materialized='table') }}\n\nselect\n    payment_type::int as payment_type_key,\n    case payment_type::int\n        when 1 then 'Credit card'\n        when 2 then 'Cash'\n        when 3 then 'No charge'\n        when 4 then 'Dispute'\n        when 5 then 'Unknown'\n        when 6 then 'Voided trip'\n        else 'Other'\n    end as payment_type_name\nfrom silver.trips_silver_clean\nwhere payment_type is not null\ngroup by payment_type\norder by payment_type_key", "file_path": "/home/src/dbts/silver_transformations/models/gold/dim_payment_type.sql", "language": "sql", "type": "dbt", "uuid": "dbts/silver_transformations/models/gold/dim_payment_type"}, "/home/src/dbts/silver_transformations/models/gold/dim_vendor.sql:dbt:sql:home/src/dbts/silver transformations/models/gold/dim vendor": {"content": "{{ config(materialized='table') }}\n\nwith vendors as (\n\n    select distinct\n        vendorid::int as vendor_key\n    from silver.trips_silver_clean\n    where vendorid is not null\n\n)\n\nselect\n    vendor_key,\n    case vendor_key\n        when 1 then 'Creative Mobile Technologies'\n        when 2 then 'VeriFone Inc.'\n        else 'Other / Unknown'\n    end as vendor_name\nfrom vendors\norder by vendor_key", "file_path": "/home/src/dbts/silver_transformations/models/gold/dim_vendor.sql", "language": "sql", "type": "dbt", "uuid": "dbts/silver_transformations/models/gold/dim_vendor"}, "/home/src/dbts/silver_transformations/models/gold/fct_trips.sql:dbt:sql:home/src/dbts/silver transformations/models/gold/fct trips": {"content": "{{ config(materialized='table') }}\n\nwith base as (\n\n    select\n        md5(\n            coalesce(cast(pickup_ts as text), '') || '|' ||\n            coalesce(cast(dropoff_ts as text), '') || '|' ||\n            coalesce(cast(vendorid as text), '') || '|' ||\n            coalesce(cast(pulocationid as text), '') || '|' ||\n            coalesce(cast(dolocationid as text), '') || '|' ||\n            coalesce(cast(total_amount as text), '') || '|' ||\n            coalesce(cast(trip_distance as text), '') || '|' ||\n            coalesce(service_type, '') || '|' ||\n            coalesce(source_month, '')\n        ) as trip_key,\n\n        cast(pickup_ts as date)  as pickup_date_key,\n        cast(dropoff_ts as date) as dropoff_date_key,\n\n        pulocationid as pu_zone_key,\n        dolocationid as do_zone_key,\n        service_type as service_type_key,\n        payment_type::int as payment_type_key,\n        vendorid::int as vendor_key,\n\n        pickup_ts,\n        dropoff_ts,\n\n        passenger_count,\n        trip_distance,\n        extract(epoch from (dropoff_ts - pickup_ts)) / 60.0 as trip_duration_min,\n\n        fare_amount,\n        extra,\n        mta_tax,\n        tip_amount,\n        tolls_amount,\n        improvement_surcharge,\n        congestion_surcharge,\n        airport_fee,\n        ehail_fee,\n        total_amount,\n\n        ratecodeid,\n        store_and_fwd_flag,\n        trip_type,\n        source_month\n\n    from silver.trips_silver_clean\n),\n\nvalidated as (\n\n    select\n        b.*\n    from base b\n    inner join gold.dim_zone puz\n        on b.pu_zone_key = puz.zone_key\n    inner join gold.dim_zone doz\n        on b.do_zone_key = doz.zone_key\n    inner join gold.dim_service_type st\n        on b.service_type_key = st.service_type_key\n    left join gold.dim_payment_type pt\n        on b.payment_type_key = pt.payment_type_key\n    left join gold.dim_vendor dv\n        on b.vendor_key = dv.vendor_key\n)\n\nselect\n    trip_key,\n    pickup_date_key,\n    dropoff_date_key,\n    pu_zone_key,\n    do_zone_key,\n    service_type_key,\n    payment_type_key,\n    vendor_key,\n    pickup_ts,\n    dropoff_ts,\n    passenger_count,\n    trip_distance,\n    trip_duration_min,\n    fare_amount,\n    extra,\n    mta_tax,\n    tip_amount,\n    tolls_amount,\n    improvement_surcharge,\n    congestion_surcharge,\n    airport_fee,\n    ehail_fee,\n    total_amount,\n\n    case\n        when fare_amount > 0 then tip_amount / fare_amount\n        else null\n    end as tip_pct,\n\n    case\n        when extract(epoch from (dropoff_ts - pickup_ts)) > 0\n             and trip_distance is not null\n        then trip_distance / (extract(epoch from (dropoff_ts - pickup_ts)) / 3600.0)\n        else null\n    end as avg_speed_mph,\n\n    ratecodeid,\n    store_and_fwd_flag,\n    trip_type,\n    source_month\n\nfrom validated", "file_path": "/home/src/dbts/silver_transformations/models/gold/fct_trips.sql", "language": "sql", "type": "dbt", "uuid": "dbts/silver_transformations/models/gold/fct_trips"}, "dbts/silver_transformations/models/gold/dim_zone_partitioned.sql:dbt:sql:silver transformations/models/gold/dim zone partitioned": {"content": "", "file_path": "dbts/silver_transformations/models/gold/dim_zone_partitioned.sql", "language": "sql", "type": "dbt", "uuid": "silver_transformations/models/gold/dim_zone_partitioned"}, "/home/src/custom/dim_zone_partitioned.py:custom:python:home/src/custom/dim zone partitioned": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\n\n@custom\ndef transform_custom(*args, **kwargs):\n    import psycopg2\n    from mage_ai.data_preparation.shared.secrets import get_secret_value\n\n    # Obtener secretos desde Mage\n    host = get_secret_value('POSTGRES_HOST')\n    port = int(get_secret_value('POSTGRES_PORT'))\n    dbname = get_secret_value('POSTGRES_DB')\n    user = get_secret_value('POSTGRES_USER')\n    password = get_secret_value('POSTGRES_PASSWORD')\n\n    # Conexi\u00f3n a Postgres\n    conn = psycopg2.connect(\n        host=host,\n        port=port,\n        dbname=dbname,\n        user=user,\n        password=password\n    )\n\n    sql = \"\"\"\n    DROP TABLE IF EXISTS gold.dim_zone_partitioned CASCADE;\n\n    CREATE TABLE gold.dim_zone_partitioned (\n        zone_key     INT NOT NULL,\n        borough      TEXT,\n        zone         TEXT,\n        service_zone TEXT,\n        PRIMARY KEY (zone_key)\n    ) PARTITION BY HASH (zone_key);\n\n    CREATE TABLE gold.dim_zone_partitioned_p0\n    PARTITION OF gold.dim_zone_partitioned\n    FOR VALUES WITH (MODULUS 4, REMAINDER 0);\n\n    CREATE TABLE gold.dim_zone_partitioned_p1\n    PARTITION OF gold.dim_zone_partitioned\n    FOR VALUES WITH (MODULUS 4, REMAINDER 1);\n\n    CREATE TABLE gold.dim_zone_partitioned_p2\n    PARTITION OF gold.dim_zone_partitioned\n    FOR VALUES WITH (MODULUS 4, REMAINDER 2);\n\n    CREATE TABLE gold.dim_zone_partitioned_p3\n    PARTITION OF gold.dim_zone_partitioned\n    FOR VALUES WITH (MODULUS 4, REMAINDER 3);\n\n    INSERT INTO gold.dim_zone_partitioned (\n        zone_key,\n        borough,\n        zone,\n        service_zone\n    )\n    SELECT\n        zone_key,\n        borough,\n        zone,\n        service_zone\n    FROM gold.dim_zone;\n    \"\"\"\n\n    cur = conn.cursor()\n    cur.execute(sql)\n    conn.commit()\n\n    cur.execute(\"SELECT COUNT(*) FROM gold.dim_zone_partitioned;\")\n    row_count = cur.fetchone()[0]\n\n    cur.close()\n    conn.close()\n\n    return {\n        'status': 'success',\n        'table_created': 'gold.dim_zone_partitioned',\n        'rows_inserted': row_count\n    }", "file_path": "/home/src/custom/dim_zone_partitioned.py", "language": "python", "type": "custom", "uuid": "dim_zone_partitioned"}, "/home/src/custom/dim_service_type.py:custom:python:home/src/custom/dim service type": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    import psycopg2\n    from mage_ai.data_preparation.shared.secrets import get_secret_value\n\n    host = get_secret_value('POSTGRES_HOST')\n    port = int(get_secret_value('POSTGRES_PORT'))\n    dbname = get_secret_value('POSTGRES_DB')\n    user = get_secret_value('POSTGRES_USER')\n    password = get_secret_value('POSTGRES_PASSWORD')\n\n    conn = psycopg2.connect(\n        host=host,\n        port=port,\n        dbname=dbname,\n        user=user,\n        password=password\n    )\n\n    sql = \"\"\"\n    DROP TABLE IF EXISTS gold.dim_service_type_partitioned CASCADE;\n\n    CREATE TABLE gold.dim_service_type_partitioned (\n        service_type_key  TEXT NOT NULL,\n        service_type_name TEXT,\n        PRIMARY KEY (service_type_key)\n    ) PARTITION BY LIST (service_type_key);\n\n    CREATE TABLE gold.dim_service_type_partitioned_yellow\n    PARTITION OF gold.dim_service_type_partitioned\n    FOR VALUES IN ('yellow');\n\n    CREATE TABLE gold.dim_service_type_partitioned_green\n    PARTITION OF gold.dim_service_type_partitioned\n    FOR VALUES IN ('green');\n\n    INSERT INTO gold.dim_service_type_partitioned (\n        service_type_key,\n        service_type_name\n    )\n    SELECT\n        service_type_key,\n        service_type_name\n    FROM gold.dim_service_type;\n    \"\"\"\n\n    cur = conn.cursor()\n    cur.execute(sql)\n    conn.commit()\n\n    cur.execute(\"SELECT COUNT(*) FROM gold.dim_service_type_partitioned;\")\n    row_count = cur.fetchone()[0]\n\n    cur.close()\n    conn.close()\n\n    return {\n        'status': 'success',\n        'table_created': 'gold.dim_service_type_partitioned',\n        'rows_inserted': row_count\n    }", "file_path": "/home/src/custom/dim_service_type.py", "language": "python", "type": "custom", "uuid": "dim_service_type"}, "/home/src/custom/dim_payment_type_partitioned.py:custom:python:home/src/custom/dim payment type partitioned": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    import psycopg2\n    from mage_ai.data_preparation.shared.secrets import get_secret_value\n\n    host = get_secret_value('POSTGRES_HOST')\n    port = int(get_secret_value('POSTGRES_PORT'))\n    dbname = get_secret_value('POSTGRES_DB')\n    user = get_secret_value('POSTGRES_USER')\n    password = get_secret_value('POSTGRES_PASSWORD')\n\n    conn = psycopg2.connect(\n        host=host,\n        port=port,\n        dbname=dbname,\n        user=user,\n        password=password\n    )\n\n    sql = \"\"\"\n    DROP TABLE IF EXISTS gold.dim_payment_type_partitioned CASCADE;\n\n    CREATE TABLE gold.dim_payment_type_partitioned (\n        payment_type_key  INTEGER NOT NULL,\n        payment_type_name TEXT NOT NULL,\n        PRIMARY KEY (payment_type_key)\n    ) PARTITION BY LIST (payment_type_key);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_unknown_zero\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (0);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_cash\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (1);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_card\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (2);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_no_charge\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (3);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_dispute\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (4);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_unknown\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (5);\n\n    CREATE TABLE gold.dim_payment_type_partitioned_voided_trip\n    PARTITION OF gold.dim_payment_type_partitioned\n    FOR VALUES IN (6);\n\n    INSERT INTO gold.dim_payment_type_partitioned (\n        payment_type_key,\n        payment_type_name\n    )\n    SELECT\n        payment_type_key,\n        payment_type_name\n    FROM gold.dim_payment_type;\n    \"\"\"\n\n    cur = conn.cursor()\n    cur.execute(sql)\n    conn.commit()\n\n    cur.execute(\"SELECT COUNT(*) FROM gold.dim_payment_type_partitioned;\")\n    row_count = cur.fetchone()[0]\n\n    cur.close()\n    conn.close()\n\n    return {\n        'status': 'success',\n        'table_created': 'gold.dim_payment_type_partitioned',\n        'rows_inserted': row_count\n    }", "file_path": "/home/src/custom/dim_payment_type_partitioned.py", "language": "python", "type": "custom", "uuid": "dim_payment_type_partitioned"}, "/home/src/custom/fact_table_partitioned.py:custom:python:home/src/custom/fact table partitioned": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    import psycopg2\n    from datetime import date\n    from mage_ai.data_preparation.shared.secrets import get_secret_value\n\n    host = get_secret_value('POSTGRES_HOST')\n    port = int(get_secret_value('POSTGRES_PORT'))\n    dbname = get_secret_value('POSTGRES_DB')\n    user = get_secret_value('POSTGRES_USER')\n    password = get_secret_value('POSTGRES_PASSWORD')\n\n    conn = psycopg2.connect(\n        host=host,\n        port=port,\n        dbname=dbname,\n        user=user,\n        password=password\n    )\n\n    cur = conn.cursor()\n\n    try:\n        print(\" Eliminando tabla previa si existe...\")\n        cur.execute(\"DROP TABLE IF EXISTS gold.fct_trips_partitioned CASCADE;\")\n\n        print(\" Creando tabla padre particionada...\")\n        create_parent_sql = \"\"\"\n        CREATE TABLE gold.fct_trips_partitioned (\n            trip_key TEXT NOT NULL,\n            pickup_date_key DATE NOT NULL,\n            dropoff_date_key DATE,\n            pu_zone_key INTEGER,\n            do_zone_key INTEGER,\n            service_type_key TEXT,\n            payment_type_key INTEGER,\n            vendor_key INTEGER,\n            pickup_ts TIMESTAMP,\n            dropoff_ts TIMESTAMP,\n            passenger_count NUMERIC,\n            trip_distance NUMERIC,\n            trip_duration_min NUMERIC,\n            fare_amount NUMERIC,\n            extra NUMERIC,\n            mta_tax NUMERIC,\n            tip_amount NUMERIC,\n            tolls_amount NUMERIC,\n            improvement_surcharge NUMERIC,\n            congestion_surcharge NUMERIC,\n            airport_fee NUMERIC,\n            ehail_fee NUMERIC,\n            total_amount NUMERIC,\n            tip_pct NUMERIC,\n            avg_speed_mph NUMERIC,\n            ratecodeid NUMERIC,\n            store_and_fwd_flag TEXT,\n            trip_type NUMERIC,\n            source_month TEXT,\n            PRIMARY KEY (trip_key, pickup_date_key)\n        ) PARTITION BY RANGE (pickup_date_key);\n        \"\"\"\n        cur.execute(create_parent_sql)\n\n        print(\" Detectando rango de fechas...\")\n        cur.execute(\"\"\"\n            SELECT\n                MIN(pickup_date_key)::date AS min_date,\n                MAX(pickup_date_key)::date AS max_date\n            FROM gold.fct_trips\n            WHERE pickup_date_key IS NOT NULL;\n        \"\"\")\n        result = cur.fetchone()\n        min_date, max_date = result\n\n        if min_date is None or max_date is None:\n            raise Exception(\"No existen fechas v\u00e1lidas en gold.fct_trips.\")\n\n        print(f\" Rango detectado: {min_date} -> {max_date}\")\n\n        start_date = date(min_date.year, min_date.month, 1)\n        end_date = date(max_date.year, max_date.month, 1)\n\n        current = start_date\n\n        print(\" Creando particiones mensuales...\")\n        while current <= end_date:\n            if current.month == 12:\n                next_month = date(current.year + 1, 1, 1)\n            else:\n                next_month = date(current.year, current.month + 1, 1)\n\n            partition_name = f\"fct_trips_partitioned_y{current.year}m{current.month:02d}\"\n\n            partition_sql = f\"\"\"\n            CREATE TABLE gold.{partition_name}\n            PARTITION OF gold.fct_trips_partitioned\n            FOR VALUES FROM ('{current}') TO ('{next_month}');\n            \"\"\"\n            cur.execute(partition_sql)\n\n            current = next_month\n\n        print(\" Insertando datos desde gold.fct_trips...\")\n        insert_sql = \"\"\"\n        INSERT INTO gold.fct_trips_partitioned (\n            trip_key,\n            pickup_date_key,\n            dropoff_date_key,\n            pu_zone_key,\n            do_zone_key,\n            service_type_key,\n            payment_type_key,\n            vendor_key,\n            pickup_ts,\n            dropoff_ts,\n            passenger_count,\n            trip_distance,\n            trip_duration_min,\n            fare_amount,\n            extra,\n            mta_tax,\n            tip_amount,\n            tolls_amount,\n            improvement_surcharge,\n            congestion_surcharge,\n            airport_fee,\n            ehail_fee,\n            total_amount,\n            tip_pct,\n            avg_speed_mph,\n            ratecodeid,\n            store_and_fwd_flag,\n            trip_type,\n            source_month\n        )\n        SELECT\n            trip_key,\n            pickup_date_key,\n            dropoff_date_key,\n            pu_zone_key,\n            do_zone_key,\n            service_type_key,\n            payment_type_key,\n            vendor_key,\n            pickup_ts,\n            dropoff_ts,\n            passenger_count,\n            trip_distance,\n            trip_duration_min,\n            fare_amount,\n            extra,\n            mta_tax,\n            tip_amount,\n            tolls_amount,\n            improvement_surcharge,\n            congestion_surcharge,\n            airport_fee,\n            ehail_fee,\n            total_amount,\n            tip_pct,\n            avg_speed_mph,\n            ratecodeid,\n            store_and_fwd_flag,\n            trip_type,\n            source_month\n        FROM gold.fct_trips\n        WHERE pickup_date_key IS NOT NULL;\n        \"\"\"\n        cur.execute(insert_sql)\n\n        print(\" Contando filas insertadas...\")\n        cur.execute(\"SELECT COUNT(*) FROM gold.fct_trips_partitioned;\")\n        row_count = cur.fetchone()[0]\n\n        conn.commit()\n\n        return {\n            'status': 'success',\n            'table_created': 'gold.fct_trips_partitioned',\n            'rows_inserted': row_count,\n            'min_date': str(min_date),\n            'max_date': str(max_date)\n        }\n\n    except Exception as e:\n        conn.rollback()\n        raise e\n\n    finally:\n        cur.close()\n        conn.close()", "file_path": "/home/src/custom/fact_table_partitioned.py", "language": "python", "type": "custom", "uuid": "fact_table_partitioned"}, "/home/src/custom/quality__checks.py:custom:python:home/src/custom/quality  checks": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\nimport subprocess\n\n\ndef run_command(command: str):\n    print(f\" Ejecutando: {command}\")\n\n    process = subprocess.Popen(\n        command,\n        shell=True,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.STDOUT,\n        text=True\n    )\n\n    for line in process.stdout:\n        print(line.strip())\n\n    process.wait()\n\n    if process.returncode != 0:\n        raise Exception(f\" Error ejecutando: {command}\")\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    \"\"\"\n    Ejecuta dbt tests para silver y gold\n    \"\"\"\n\n    print(\" Iniciando dbt tests...\")\n\n    # Test para modelos silver\n    run_command(\"dbt test --select silver\")\n\n    # Test para modelos gold\n    run_command(\"dbt test --select gold\")\n\n    print(\" dbt tests completados correctamente\")\n\n    return {\"status\": \"success\"}\n\n\n", "file_path": "/home/src/custom/quality__checks.py", "language": "python", "type": "custom", "uuid": "quality__checks"}, "/home/src/custom/trigger_quelity_checks.py:custom:python:home/src/custom/trigger quelity checks": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\nimport requests\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    \"\"\"\n    args: The output from any upstream parent blocks (if applicable)\n\n    Returns:\n        dict: response JSON from Mage API trigger\n    \"\"\"\n    # Endpoint del trigger API (si te falla por conexi\u00f3n en Docker, cambia localhost -> mage o el nombre del servicio)\n    TRIGGER_URL = \"http://localhost:6789/api/pipeline_schedules/4/pipeline_runs/434baa984f5b4316bf4f006ffc16af29\"\n\n    payload = {\n        \"pipeline_run\": {\n            \"variables\": {\n                \"triggered_by\": \"dbt_build_gold\"\n            }\n        }\n    }\n\n    print(f\"Calling Mage API trigger: {TRIGGER_URL}\")\n    r = requests.post(TRIGGER_URL, json=payload, timeout=30)\n    r.raise_for_status()\n\n    resp = r.json()\n    print(\"Triggered OK:\", resp)\n    return resp\n", "file_path": "/home/src/custom/trigger_quelity_checks.py", "language": "python", "type": "custom", "uuid": "trigger_quelity_checks"}, "/home/src/data_exporters/data_exporter_taxi.py:data_exporter:python:home/src/data exporters/data exporter taxi": {"content": "import os\nimport time\nimport gc\nfrom datetime import datetime\nfrom urllib.request import urlretrieve\n\nimport pandas as pd\nimport pyarrow.dataset as ds\nfrom sqlalchemy import create_engine, text\nfrom mage_ai.data_preparation.shared.secrets import get_secret_value\n\nif 'data_exporter' not in globals():\n    from mage_ai.data_preparation.decorators import data_exporter\n\n\n# -----------------------------\n# Conexi\u00f3n a Postgres (Mage Secrets)\n# -----------------------------\ndef pg_engine():\n    host = get_secret_value(\"POSTGRES_HOST\")\n    port = get_secret_value(\"POSTGRES_PORT\") or \"5432\"\n    db   = get_secret_value(\"POSTGRES_DB\")\n    user = get_secret_value(\"POSTGRES_USER\")\n    pwd  = get_secret_value(\"POSTGRES_PASSWORD\")\n    return create_engine(f\"postgresql+psycopg2://{user}:{pwd}@{host}:{port}/{db}\")\n\n\n# -----------------------------\n# DDL: schema + tablas + \u00edndice\n# -----------------------------\ndef ensure_bronze_tables(conn):\n    conn.execute(text(\"CREATE SCHEMA IF NOT EXISTS bronze;\"))\n\n    conn.execute(text(\"\"\"\n        CREATE TABLE IF NOT EXISTS bronze.trips_raw (\n          ingest_ts     TIMESTAMP NOT NULL,\n          source_month  TEXT      NOT NULL,\n          service_type  TEXT      NOT NULL,\n\n          vendorid              INTEGER NULL,\n          tpep_pickup_datetime  TIMESTAMP NULL,\n          tpep_dropoff_datetime TIMESTAMP NULL,\n          lpep_pickup_datetime  TIMESTAMP NULL,\n          lpep_dropoff_datetime TIMESTAMP NULL,\n\n          passenger_count       NUMERIC NULL,\n          trip_distance         NUMERIC NULL,\n\n          pulocationid          INTEGER NULL,\n          dolocationid          INTEGER NULL,\n\n          ratecodeid            NUMERIC NULL,\n          store_and_fwd_flag    TEXT NULL,\n\n          payment_type          INTEGER NULL,\n\n          fare_amount           NUMERIC NULL,\n          extra                 NUMERIC NULL,\n          mta_tax               NUMERIC NULL,\n          tip_amount            NUMERIC NULL,\n          tolls_amount          NUMERIC NULL,\n          improvement_surcharge NUMERIC NULL,\n          total_amount          NUMERIC NULL,\n          congestion_surcharge  NUMERIC NULL,\n          airport_fee           NUMERIC NULL,\n\n          ehail_fee             NUMERIC NULL,\n          trip_type             NUMERIC NULL\n        );\n    \"\"\"))\n\n    conn.execute(text(\"\"\"\n        CREATE INDEX IF NOT EXISTS idx_trips_raw_month_service\n        ON bronze.trips_raw (source_month, service_type);\n    \"\"\"))\n\n    conn.execute(text(\"\"\"\n        CREATE TABLE IF NOT EXISTS bronze.ingest_coverage (\n          year_month   TEXT NOT NULL,\n          service_type TEXT NOT NULL,\n          status       TEXT NOT NULL,\n          row_count    BIGINT NULL,\n          updated_ts   TIMESTAMP NOT NULL DEFAULT NOW(),\n          PRIMARY KEY (year_month, service_type)\n        );\n    \"\"\"))\n\n\n# -----------------------------\n# Alinear DF al schema objetivo\n# -----------------------------\nTARGET_COLS = [\n    \"ingest_ts\", \"source_month\", \"service_type\",\n    \"vendorid\",\n    \"tpep_pickup_datetime\", \"tpep_dropoff_datetime\",\n    \"lpep_pickup_datetime\", \"lpep_dropoff_datetime\",\n    \"passenger_count\", \"trip_distance\",\n    \"pulocationid\", \"dolocationid\",\n    \"ratecodeid\", \"store_and_fwd_flag\",\n    \"payment_type\",\n    \"fare_amount\", \"extra\", \"mta_tax\", \"tip_amount\", \"tolls_amount\",\n    \"improvement_surcharge\", \"total_amount\", \"congestion_surcharge\", \"airport_fee\",\n    \"ehail_fee\", \"trip_type\",\n]\n\ndef align_to_target_schema(df: pd.DataFrame) -> pd.DataFrame:\n    df = df.copy()\n    df.columns = [c.lower() for c in df.columns]\n\n    rename_map = {\n        \"pu_locationid\": \"pulocationid\",\n        \"do_locationid\": \"dolocationid\",\n    }\n    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})\n\n    for c in TARGET_COLS:\n        if c not in df.columns:\n            df[c] = None\n\n    return df[TARGET_COLS]\n\n\ndef upsert_coverage(conn, ym, st, status, row_count=None):\n    conn.execute(text(\"\"\"\n        INSERT INTO bronze.ingest_coverage(year_month, service_type, status, row_count, updated_ts)\n        VALUES (:ym, :st, :status, :rc, NOW())\n        ON CONFLICT (year_month, service_type)\n        DO UPDATE SET status=:status, row_count=:rc, updated_ts=NOW()\n    \"\"\"), {\"ym\": ym, \"st\": st, \"status\": status, \"rc\": row_count})\n\n\ndef get_coverage_status(conn, ym, st):\n    row = conn.execute(\n        text(\"\"\"\n            SELECT status, row_count, updated_ts\n            FROM bronze.ingest_coverage\n            WHERE year_month=:ym AND service_type=:st\n        \"\"\"),\n        {\"ym\": ym, \"st\": st}\n    ).fetchone()\n    if not row:\n        return None, None, None\n    return row[0], row[1], row[2]\n\n\ndef coverage_summary(conn):\n    \"\"\"\n    Devuelve conteos por status para TODO lo que exista en ingest_coverage.\n    \"\"\"\n    rows = conn.execute(text(\"\"\"\n        SELECT status, COUNT(*) AS n\n        FROM bronze.ingest_coverage\n        GROUP BY status\n        ORDER BY status\n    \"\"\")).fetchall()\n    return {r[0]: int(r[1]) for r in rows}\n\n\n# -----------------------------\n# Exporter: descarga local + streaming + RESUME\n# -----------------------------\n@data_exporter\ndef export_data(data, *args, **kwargs):\n    # unwrap por si Mage envuelve\n    jobs = data\n    if isinstance(data, dict):\n        for v in data.values():\n            if isinstance(v, list):\n                jobs = v\n                break\n\n    if not isinstance(jobs, list) or not jobs:\n        raise ValueError(f\"Se esperaba lista de jobs. Lleg\u00f3: {type(data)}\")\n\n    engine = pg_engine()\n\n    # Par\u00e1metros\n    batch_size = int(kwargs.get(\"batch_size\", 25_000))     # lectura parquet -> batches\n    chunksize  = int(kwargs.get(\"chunksize\", 10_000))      # escritura SQL -> chunks\n    log_every_batches = int(kwargs.get(\"log_every_batches\", 5))\n    tmp_dir = kwargs.get(\"tmp_dir\", \"/tmp/tlc_parquet\")\n\n    # resume control\n    resume = str(kwargs.get(\"resume\", \"true\")).lower() in (\"1\", \"true\", \"yes\", \"y\")\n    force_reload = str(kwargs.get(\"force_reload\", \"false\")).lower() in (\"1\", \"true\", \"yes\", \"y\")\n\n    os.makedirs(tmp_dir, exist_ok=True)\n\n    total = len(jobs)\n    ok = 0\n    missing = 0\n    failed = 0\n    skipped = 0\n    pending = 0\n\n    print(\"=\" * 118, flush=True)\n    print(\"[START] Exporter STREAMING (descarga local) -> bronze.trips_raw\", flush=True)\n    print(f\"[CONFIG] jobs={total} | batch_size(read)={batch_size} | chunksize(sql)={chunksize} | tmp_dir={tmp_dir}\", flush=True)\n    print(f\"[CONFIG] resume={resume} | force_reload={force_reload} | log_every_batches={log_every_batches}\", flush=True)\n    print(\"=\" * 118, flush=True)\n\n    # Asegura tablas + resumen cobertura\n    with engine.begin() as conn:\n        ensure_bronze_tables(conn)\n        summ = coverage_summary(conn)\n\n    print(\"[INIT] Tablas bronze aseguradas (trips_raw, ingest_coverage)\", flush=True)\n    print(f\"[INIT] ingest_coverage summary: {summ}\", flush=True)\n    print(\"[INIT] Interpretaci\u00f3n r\u00e1pida:\", flush=True)\n    print(\"       - loaded  => ya ingerido (se puede SKIP si resume=true)\", flush=True)\n    print(\"       - missing => fall\u00f3 descarga (se reintenta)\", flush=True)\n    print(\"       - failed  => fall\u00f3 DB/dataset (se reintenta)\", flush=True)\n    print(\"=\" * 118, flush=True)\n\n    t_all = time.time()\n\n    for i, job in enumerate(jobs, start=1):\n        ym = job[\"year_month\"]\n        st = job[\"service_type\"]\n        url = job[\"url_parquet\"]\n        local_path = os.path.join(tmp_dir, f\"{st}_{ym}.parquet\")\n\n        print(\"\\n\" + \"-\" * 118, flush=True)\n        print(f\"[JOB {i}/{total}] {st} {ym}\", flush=True)\n\n        # 0) RESUME: decide SKIP o PENDING\n        status = None\n        rc = None\n        updated_ts = None\n        if resume and not force_reload:\n            with engine.begin() as conn:\n                status, rc, updated_ts = get_coverage_status(conn, ym, st)\n\n            if status == \"loaded\":\n                skipped += 1\n                print(f\"[JOB {i}] SKIP  already loaded | row_count={rc} | updated_ts={updated_ts}\", flush=True)\n                print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n                continue\n            else:\n                pending += 1\n                print(f\"[JOB {i}] PENDING  will process | current_status={status}\", flush=True)\n\n        # si force_reload=True, siempre procesa\n        if force_reload:\n            pending += 1\n            print(f\"[JOB {i}] FORCE_RELOAD  will re-process (ignoring ingest_coverage)\", flush=True)\n\n        print(f\"[JOB {i}] URL={url}\", flush=True)\n\n        # 1) Descargar parquet\n        try:\n            t_dl = time.time()\n            if not os.path.exists(local_path) or os.path.getsize(local_path) == 0:\n                print(f\"[JOB {i}] Downloading -> {local_path}\", flush=True)\n                urlretrieve(url, local_path)\n\n            size_mb = os.path.getsize(local_path) / (1024 * 1024)\n            print(f\"[JOB {i}] Download OK | size={size_mb:.1f} MB | time={time.time()-t_dl:.2f}s\", flush=True)\n        except Exception as e:\n            missing += 1\n            print(f\"[JOB {i}] ERROR download  | {type(e).__name__}: {e}\", flush=True)\n            with engine.begin() as conn:\n                upsert_coverage(conn, ym, st, \"missing\", None)\n\n            try:\n                if os.path.exists(local_path):\n                    os.remove(local_path)\n                    print(f\"[JOB {i}] Cleaned partial file after download error\", flush=True)\n            except Exception:\n                pass\n\n            print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n            continue\n\n        # 2) Dataset local\n        try:\n            t_ds = time.time()\n            dataset = ds.dataset(local_path, format=\"parquet\")\n            print(f\"[JOB {i}] dataset(local) OK | time={time.time()-t_ds:.2f}s\", flush=True)\n        except Exception as e:\n            failed += 1\n            print(f\"[JOB {i}] ERROR dataset(local)  | {type(e).__name__}: {e}\", flush=True)\n            with engine.begin() as conn:\n                upsert_coverage(conn, ym, st, \"failed\", None)\n\n            try:\n                os.remove(local_path)\n                print(f\"[JOB {i}] Cleaned file after dataset error\", flush=True)\n            except Exception:\n                pass\n\n            print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n            continue\n\n        total_rows = 0\n        batch_idx = 0\n        t_job = time.time()\n\n        try:\n            with engine.begin() as conn:\n                # 3) Idempotencia\n                t_del = time.time()\n                conn.execute(\n                    text(\"DELETE FROM bronze.trips_raw WHERE source_month=:ym AND service_type=:st\"),\n                    {\"ym\": ym, \"st\": st}\n                )\n                print(f\"[JOB {i}] DELETE OK | time={time.time()-t_del:.2f}s\", flush=True)\n\n                # 4) Streaming batches -> to_sql\n                t_stream = time.time()\n                for record_batch in dataset.to_batches(batch_size=batch_size):\n                    batch_idx += 1\n                    df_chunk = record_batch.to_pandas()\n\n                    df_chunk[\"ingest_ts\"] = datetime.utcnow()\n                    df_chunk[\"source_month\"] = ym\n                    df_chunk[\"service_type\"] = st\n\n                    df_chunk = align_to_target_schema(df_chunk)\n\n                    df_chunk.to_sql(\n                        name=\"trips_raw\",\n                        con=conn,\n                        schema=\"bronze\",\n                        if_exists=\"append\",\n                        index=False,\n                        method=\"multi\",\n                        chunksize=chunksize\n                    )\n\n                    total_rows += len(df_chunk)\n\n                    del df_chunk\n                    gc.collect()\n\n                    if log_every_batches > 0 and batch_idx % log_every_batches == 0:\n                        print(f\"[JOB {i}] PROGRESS | batches={batch_idx} | rows_loaded={total_rows} | elapsed={time.time()-t_stream:.1f}s\", flush=True)\n\n                upsert_coverage(conn, ym, st, \"loaded\", total_rows)\n\n            ok += 1\n            print(f\"[JOB {i}] DONE OK  | batches={batch_idx} | rows_loaded={total_rows} | time={time.time()-t_job:.2f}s\", flush=True)\n\n        except Exception as e:\n            failed += 1\n            print(f\"[JOB {i}] FAILED DB load  | {type(e).__name__}: {e}\", flush=True)\n            with engine.begin() as conn:\n                upsert_coverage(conn, ym, st, \"failed\", None)\n\n        finally:\n            # liberar dataset + limpiar parquet local\n            try:\n                del dataset\n            except Exception:\n                pass\n            gc.collect()\n\n            try:\n                if os.path.exists(local_path):\n                    os.remove(local_path)\n                    print(f\"[JOB {i}] Cleaned local file: {local_path}\", flush=True)\n            except Exception as e:\n                print(f\"[JOB {i}] WARN no pude borrar local file | {e}\", flush=True)\n\n        print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n\n    total_s = time.time() - t_all\n    print(\"\\n\" + \"=\" * 118, flush=True)\n    print(\"[DONE] INGEST FINALIZADO (STREAMING + LOCAL DOWNLOAD)\", flush=True)\n    print(f\"[SUMMARY] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed} | total_jobs={total}\", flush=True)\n    print(f\"[SUMMARY] total_time={(total_s/60):.2f} min\", flush=True)\n    print(\"=\" * 118, flush=True)\n\n    return {\n        \"total\": total,\n        \"ok\": ok,\n        \"skipped\": skipped,\n        \"pending\": pending,\n        \"missing\": missing,\n        \"failed\": failed\n    }\n\n", "file_path": "/home/src/data_exporters/data_exporter_taxi.py", "language": "python", "type": "data_exporter", "uuid": "data_exporter_taxi"}}, "custom_block_template": {"custom_templates/blocks/dbt_run_silver_custom:dbt:yaml": {"block_type": "dbt", "color": null, "configuration": null, "description": null, "language": "yaml", "name": null, "pipeline": {}, "tags": [], "user": {"username": "admin"}, "template_uuid": "dbt_run_s
ver/trips_silver.sql:dbt:sql:silver transformations/models/silver/trips silver": {"content": "{{ config(materialized='view') }}\n\nwith base as (\n\n  select\n    ingest_ts,\n    source_month,\n    service_type,\n    vendorid,\n\n    -- unificamos timestamps para yellow/green\n    coalesce(tpep_pickup_datetime, lpep_pickup_datetime)   as pickup_ts,\n    coalesce(tpep_dropoff_datetime, lpep_dropoff_datetime) as dropoff_ts,\n\n    passenger_count,\n    trip_distance,\n    pulocationid,\n    dolocationid,\n    ratecodeid,\n    store_and_fwd_flag,\n    payment_type,\n\n    fare_amount,\n    extra,\n    mta_tax,\n    tip_amount,\n    tolls_amount,\n    improvement_surcharge,\n    congestion_surcharge,\n    airport_fee,\n    ehail_fee,\n    total_amount,\n    trip_type\n  from bronze.trips_raw\n\n),\n\nfiltered as (\n\n  select *\n  from base\n  where\n    pickup_ts is not null\n    and dropoff_ts is not null\n    and pickup_ts <= dropoff_ts\n    and trip_distance >= 0\n    and total_amount >= 0\n\n),\n\nenriched as (\n\n  select\n    f.*,\n\n    -- Pickup zone enrichment\n    pu.borough       as pu_borough,\n    pu.zone          as pu_zone,\n    pu.service_zone  as pu_service_zone,\n\n    -- Dropoff zone enrichment\n    dz.borough       as do_borough,\n    dz.zone          as do_zone,\n    dz.service_zone  as do_service_zone\n\n  from filtered f\n  left join bronze.taxi_zone_lookup pu\n    on f.pulocationid = pu.location_id\n  left join bronze.taxi_zone_lookup dz\n    on f.dolocationid = dz.location_id\n\n)\n\nselect *\nfrom enriched", "file_path": "dbts/silver_transformations/models/silver/trips_silver.sql", "language": "sql", "type": "dbt", "uuid": "silver_transformations/models/silver/trips_silver"}, "dbts/silver_transformations/target/compiled/silver_transformations/models/silver/trips_silver.sql:dbt:sql:silver transformations/target/compiled/silver transformations/models/silver/trips silver": {"content": "\n\nwith base as (\n\n  select\n    ingest_ts,\n    source_mo
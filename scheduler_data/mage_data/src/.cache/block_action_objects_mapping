{"block_file": {"custom/dbt_silver_cmd.py:custom:python:dbt silver cmd": {"content": "import os\nimport subprocess\n\nif 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    \"\"\"\n    Runs dbt to build Silver models.\n\n    This avoids Mage's DBT block profiles interpolation issue by calling dbt directly.\n    \"\"\"\n    project_dir = \"/home/src/dbt_project\"\n    profiles_dir = \"/root/.dbt\"  # contains /root/.dbt/profiles.yml\n    target = \"dev\"\n    select_path = \"models/silver\"\n\n    cmd = [\n        \"dbt\", \"run\",\n        \"--select\", select_path,\n        \"--target\", target,\n        \"--project-dir\", project_dir,\n        \"--profiles-dir\", profiles_dir,\n    ]\n\n    env = os.environ.copy()\n    env[\"DBT_PROFILES_DIR\"] = profiles_dir\n\n    res = subprocess.run(\n        cmd,\n        cwd=project_dir,\n        env=env,\n        capture_output=True,\n        text=True,\n    )\n\n    # Print logs into Mage block output\n    stdout = res.stdout or \"\"\n    stderr = res.stderr or \"\"\n    print(stdout)\n    if stderr.strip():\n        print(stderr)\n\n    if res.returncode != 0:\n        raise Exception(f\"dbt run failed (code={res.returncode}). See logs above.\")\n\n    # Return something small + useful for the next blocks / debugging\n    return {\n        \"status\": \"success\",\n        \"command\": \" \".join(cmd),\n        \"project_dir\": project_dir,\n        \"profiles_dir\": profiles_dir,\n        \"target\": target,\n        \"select\": select_path,\n    }\n\n\n@test\ndef test_output(output, *args) -> None:\n    assert output is not None, \"The output is undefined\"\n    assert isinstance(output, dict), \"Expected dict output\"\n    assert output.get(\"status\") == \"success\", \"dbt did not complete successfully\"", "file_path": "custom/dbt_silver_cmd.py", "language": "python", "type": "custom", "uuid": "dbt_silver_cmd"}, "custom/run_dbt_silver_cmd.sql:custom:sql:run dbt silver cmd": {"content": "-- Docimport os\nimport subprocess\n\ndef run_dbt():\n    project_dir = \"/home/src/dbt_project\"\n    profiles_dir = \"/root/.dbt\"  # aqu\u00ed est\u00e1 tu profiles.yml que ya funciona\n\n    cmd = [\n        \"dbt\", \"run\",\n        \"--select\", \"models/silver\",\n        \"--target\", \"dev\",\n        \"--project-dir\", project_dir,\n        \"--profiles-dir\", profiles_dir,\n    ]\n\n    env = os.environ.copy()\n    # (opcional) fuerza a dbt a usar ese directorio\n    env[\"DBT_PROFILES_DIR\"] = profiles_dir\n\n    result = subprocess.run(\n        cmd,\n        cwd=project_dir,\n        env=env,\n        capture_output=True,\n        text=True,\n    )\n\n    print(result.stdout)\n    if result.returncode != 0:\n        print(result.stderr)\n        raise Exception(f\"dbt failed with code {result.returncode}\")\n\nrun_dbt()s: https://docs.mage.ai/guides/sql-blocks\n", "file_path": "custom/run_dbt_silver_cmd.sql", "language": "sql", "type": "custom", "uuid": "run_dbt_silver_cmd"}, "custom/trigger_dbt_silver.py:custom:python:trigger dbt silver": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    \"\"\"\n    args: The output from any upstream parent blocks (if applicable)\n\n    Returns:\n        Anything (e.g. data frame, dictionary, array, int, str, etc.)\n    \"\"\"\n    # Specify your custom logic here\n\n    return {}\n\n\n@test\ndef test_output(output, *args) -> None:\n    \"\"\"\n    Template code for testing the output of the block.\n    \"\"\"\n    assert output is not None, 'The output is undefined'\n", "file_path": "custom/trigger_dbt_silver.py", "language": "python", "type": "custom", "uuid": "trigger_dbt_silver"}, "custom/trigger_dbt_silver1.py:custom:python:trigger dbt silver1": {"content": "if 'custom' not in globals():\n    from mage_ai.data_preparation.decorators import custom\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\nimport requests\n\n\n@custom\ndef transform_custom(*args, **kwargs):\n    \"\"\"\n    args: The output from any upstream parent blocks (if applicable)\n\n    Returns:\n        dict: response JSON from Mage API trigger\n    \"\"\"\n    # Endpoint del trigger API (si te falla por conexi\u00f3n en Docker, cambia localhost -> mage o el nombre del servicio)\n    TRIGGER_URL = \"http://localhost:6789/api/pipeline_schedules/2/pipeline_runs/d139915d8c434699810aa556f84dd52f\"\n\n    payload = {\n        \"pipeline_run\": {\n            \"variables\": {\n                \"triggered_by\": \"ingest_bronze\"\n            }\n        }\n    }\n\n    print(f\"Calling Mage API trigger: {TRIGGER_URL}\")\n    r = requests.post(TRIGGER_URL, json=payload, timeout=30)\n    r.raise_for_status()\n\n    resp = r.json()\n    print(\"Triggered OK:\", resp)\n    return resp\n\n", "file_path": "custom/trigger_dbt_silver1.py", "language": "python", "type": "custom", "uuid": "trigger_dbt_silver1"}, "data_exporters/data_exporter_taxi.py:data_exporter:python:data exporter taxi": {"content": "import os\nimport time\nimport gc\nfrom datetime import datetime\nfrom urllib.request import urlretrieve\n\nimport pandas as pd\nimport pyarrow.dataset as ds\nfrom sqlalchemy import create_engine, text\nfrom mage_ai.data_preparation.shared.secrets import get_secret_value\n\nif 'data_exporter' not in globals():\n    from mage_ai.data_preparation.decorators import data_exporter\n\n\n# -----------------------------\n# Conexi\u00f3n a Postgres (Mage Secrets)\n# -----------------------------\ndef pg_engine():\n    host = get_secret_value(\"POSTGRES_HOST\")\n    port = get_secret_value(\"POSTGRES_PORT\") or \"5432\"\n    db   = get_secret_value(\"POSTGRES_DB\")\n    user = get_secret_value(\"POSTGRES_USER\")\n    pwd  = get_secret_value(\"POSTGRES_PASSWORD\")\n    return create_engine(f\"postgresql+psycopg2://{user}:{pwd}@{host}:{port}/{db}\")\n\n\n# -----------------------------\n# DDL: schema + tablas + \u00edndice\n# -----------------------------\ndef ensure_bronze_tables(conn):\n    conn.execute(text(\"CREATE SCHEMA IF NOT EXISTS bronze;\"))\n\n    conn.execute(text(\"\"\"\n        CREATE TABLE IF NOT EXISTS bronze.trips_raw (\n          ingest_ts     TIMESTAMP NOT NULL,\n          source_month  TEXT      NOT NULL,\n          service_type  TEXT      NOT NULL,\n\n          vendorid              INTEGER NULL,\n          tpep_pickup_datetime  TIMESTAMP NULL,\n          tpep_dropoff_datetime TIMESTAMP NULL,\n          lpep_pickup_datetime  TIMESTAMP NULL,\n          lpep_dropoff_datetime TIMESTAMP NULL,\n\n          passenger_count       NUMERIC NULL,\n          trip_distance         NUMERIC NULL,\n\n          pulocationid          INTEGER NULL,\n          dolocationid          INTEGER NULL,\n\n          ratecodeid            NUMERIC NULL,\n          store_and_fwd_flag    TEXT NULL,\n\n          payment_type          INTEGER NULL,\n\n          fare_amount           NUMERIC NULL,\n          extra                 NUMERIC NULL,\n          mta_tax               NUMERIC NULL,\n          tip_amount            NUMERIC NULL,\n          tolls_amount          NUMERIC NULL,\n          improvement_surcharge NUMERIC NULL,\n          total_amount          NUMERIC NULL,\n          congestion_surcharge  NUMERIC NULL,\n          airport_fee           NUMERIC NULL,\n\n          ehail_fee             NUMERIC NULL,\n          trip_type             NUMERIC NULL\n        );\n    \"\"\"))\n\n    conn.execute(text(\"\"\"\n        CREATE INDEX IF NOT EXISTS idx_trips_raw_month_service\n        ON bronze.trips_raw (source_month, service_type);\n    \"\"\"))\n\n    conn.execute(text(\"\"\"\n        CREATE TABLE IF NOT EXISTS bronze.ingest_coverage (\n          year_month   TEXT NOT NULL,\n          service_type TEXT NOT NULL,\n          status       TEXT NOT NULL,\n          row_count    BIGINT NULL,\n          updated_ts   TIMESTAMP NOT NULL DEFAULT NOW(),\n          PRIMARY KEY (year_month, service_type)\n        );\n    \"\"\"))\n\n\n# -----------------------------\n# Alinear DF al schema objetivo\n# -----------------------------\nTARGET_COLS = [\n    \"ingest_ts\", \"source_month\", \"service_type\",\n    \"vendorid\",\n    \"tpep_pickup_datetime\", \"tpep_dropoff_datetime\",\n    \"lpep_pickup_datetime\", \"lpep_dropoff_datetime\",\n    \"passenger_count\", \"trip_distance\",\n    \"pulocationid\", \"dolocationid\",\n    \"ratecodeid\", \"store_and_fwd_flag\",\n    \"payment_type\",\n    \"fare_amount\", \"extra\", \"mta_tax\", \"tip_amount\", \"tolls_amount\",\n    \"improvement_surcharge\", \"total_amount\", \"congestion_surcharge\", \"airport_fee\",\n    \"ehail_fee\", \"trip_type\",\n]\n\ndef align_to_target_schema(df: pd.DataFrame) -> pd.DataFrame:\n    df = df.copy()\n    df.columns = [c.lower() for c in df.columns]\n\n    rename_map = {\n        \"pu_locationid\": \"pulocationid\",\n        \"do_locationid\": \"dolocationid\",\n    }\n    df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})\n\n    for c in TARGET_COLS:\n        if c not in df.columns:\n            df[c] = None\n\n    return df[TARGET_COLS]\n\n\ndef upsert_coverage(conn, ym, st, status, row_count=None):\n    conn.execute(text(\"\"\"\n        INSERT INTO bronze.ingest_coverage(year_month, service_type, status, row_count, updated_ts)\n        VALUES (:ym, :st, :status, :rc, NOW())\n        ON CONFLICT (year_month, service_type)\n        DO UPDATE SET status=:status, row_count=:rc, updated_ts=NOW()\n    \"\"\"), {\"ym\": ym, \"st\": st, \"status\": status, \"rc\": row_count})\n\n\ndef get_coverage_status(conn, ym, st):\n    row = conn.execute(\n        text(\"\"\"\n            SELECT status, row_count, updated_ts\n            FROM bronze.ingest_coverage\n            WHERE year_month=:ym AND service_type=:st\n        \"\"\"),\n        {\"ym\": ym, \"st\": st}\n    ).fetchone()\n    if not row:\n        return None, None, None\n    return row[0], row[1], row[2]\n\n\ndef coverage_summary(conn):\n    \"\"\"\n    Devuelve conteos por status para TODO lo que exista en ingest_coverage.\n    \"\"\"\n    rows = conn.execute(text(\"\"\"\n        SELECT status, COUNT(*) AS n\n        FROM bronze.ingest_coverage\n        GROUP BY status\n        ORDER BY status\n    \"\"\")).fetchall()\n    return {r[0]: int(r[1]) for r in rows}\n\n\n# -----------------------------\n# Exporter: descarga local + streaming + RESUME\n# -----------------------------\n@data_exporter\ndef export_data(data, *args, **kwargs):\n    # unwrap por si Mage envuelve\n    jobs = data\n    if isinstance(data, dict):\n        for v in data.values():\n            if isinstance(v, list):\n                jobs = v\n                break\n\n    if not isinstance(jobs, list) or not jobs:\n        raise ValueError(f\"Se esperaba lista de jobs. Lleg\u00f3: {type(data)}\")\n\n    engine = pg_engine()\n\n    # Par\u00e1metros\n    batch_size = int(kwargs.get(\"batch_size\", 25_000))     # lectura parquet -> batches\n    chunksize  = int(kwargs.get(\"chunksize\", 10_000))      # escritura SQL -> chunks\n    log_every_batches = int(kwargs.get(\"log_every_batches\", 5))\n    tmp_dir = kwargs.get(\"tmp_dir\", \"/tmp/tlc_parquet\")\n\n    # resume control\n    resume = str(kwargs.get(\"resume\", \"true\")).lower() in (\"1\", \"true\", \"yes\", \"y\")\n    force_reload = str(kwargs.get(\"force_reload\", \"false\")).lower() in (\"1\", \"true\", \"yes\", \"y\")\n\n    os.makedirs(tmp_dir, exist_ok=True)\n\n    total = len(jobs)\n    ok = 0\n    missing = 0\n    failed = 0\n    skipped = 0\n    pending = 0\n\n    print(\"=\" * 118, flush=True)\n    print(\"[START] Exporter STREAMING (descarga local) -> bronze.trips_raw\", flush=True)\n    print(f\"[CONFIG] jobs={total} | batch_size(read)={batch_size} | chunksize(sql)={chunksize} | tmp_dir={tmp_dir}\", flush=True)\n    print(f\"[CONFIG] resume={resume} | force_reload={force_reload} | log_every_batches={log_every_batches}\", flush=True)\n    print(\"=\" * 118, flush=True)\n\n    # Asegura tablas + resumen cobertura\n    with engine.begin() as conn:\n        ensure_bronze_tables(conn)\n        summ = coverage_summary(conn)\n\n    print(\"[INIT] Tablas bronze aseguradas (trips_raw, ingest_coverage)\", flush=True)\n    print(f\"[INIT] ingest_coverage summary: {summ}\", flush=True)\n    print(\"[INIT] Interpretaci\u00f3n r\u00e1pida:\", flush=True)\n    print(\"       - loaded  => ya ingerido (se puede SKIP si resume=true)\", flush=True)\n    print(\"       - missing => fall\u00f3 descarga (se reintenta)\", flush=True)\n    print(\"       - failed  => fall\u00f3 DB/dataset (se reintenta)\", flush=True)\n    print(\"=\" * 118, flush=True)\n\n    t_all = time.time()\n\n    for i, job in enumerate(jobs, start=1):\n        ym = job[\"year_month\"]\n        st = job[\"service_type\"]\n        url = job[\"url_parquet\"]\n        local_path = os.path.join(tmp_dir, f\"{st}_{ym}.parquet\")\n\n        print(\"\\n\" + \"-\" * 118, flush=True)\n        print(f\"[JOB {i}/{total}] {st} {ym}\", flush=True)\n\n        # 0) RESUME: decide SKIP o PENDING\n        status = None\n        rc = None\n        updated_ts = None\n        if resume and not force_reload:\n            with engine.begin() as conn:\n                status, rc, updated_ts = get_coverage_status(conn, ym, st)\n\n            if status == \"loaded\":\n                skipped += 1\n                print(f\"[JOB {i}] SKIP \u2705 already loaded | row_count={rc} | updated_ts={updated_ts}\", flush=True)\n                print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n                continue\n            else:\n                pending += 1\n                print(f\"[JOB {i}] PENDING \u23f3 will process | current_status={status}\", flush=True)\n\n        # si force_reload=True, siempre procesa\n        if force_reload:\n            pending += 1\n            print(f\"[JOB {i}] FORCE_RELOAD \ud83d\udd01 will re-process (ignoring ingest_coverage)\", flush=True)\n\n        print(f\"[JOB {i}] URL={url}\", flush=True)\n\n        # 1) Descargar parquet\n        try:\n            t_dl = time.time()\n            if not os.path.exists(local_path) or os.path.getsize(local_path) == 0:\n                print(f\"[JOB {i}] Downloading -> {local_path}\", flush=True)\n                urlretrieve(url, local_path)\n\n            size_mb = os.path.getsize(local_path) / (1024 * 1024)\n            print(f\"[JOB {i}] Download OK | size={size_mb:.1f} MB | time={time.time()-t_dl:.2f}s\", flush=True)\n        except Exception as e:\n            missing += 1\n            print(f\"[JOB {i}] ERROR download \u274c | {type(e).__name__}: {e}\", flush=True)\n            with engine.begin() as conn:\n                upsert_coverage(conn, ym, st, \"missing\", None)\n\n            try:\n                if os.path.exists(local_path):\n                    os.remove(local_path)\n                    print(f\"[JOB {i}] Cleaned partial file after download error\", flush=True)\n            except Exception:\n                pass\n\n            print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n            continue\n\n        # 2) Dataset local\n        try:\n            t_ds = time.time()\n            dataset = ds.dataset(local_path, format=\"parquet\")\n            print(f\"[JOB {i}] dataset(local) OK | time={time.time()-t_ds:.2f}s\", flush=True)\n        except Exception as e:\n            failed += 1\n            print(f\"[JOB {i}] ERROR dataset(local) \u274c | {type(e).__name__}: {e}\", flush=True)\n            with engine.begin() as conn:\n                upsert_coverage(conn, ym, st, \"failed\", None)\n\n            try:\n                os.remove(local_path)\n                print(f\"[JOB {i}] Cleaned file after dataset error\", flush=True)\n            except Exception:\n                pass\n\n            print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n            continue\n\n        total_rows = 0\n        batch_idx = 0\n        t_job = time.time()\n\n        try:\n            with engine.begin() as conn:\n                # 3) Idempotencia\n                t_del = time.time()\n                conn.execute(\n                    text(\"DELETE FROM bronze.trips_raw WHERE source_month=:ym AND service_type=:st\"),\n                    {\"ym\": ym, \"st\": st}\n                )\n                print(f\"[JOB {i}] DELETE OK | time={time.time()-t_del:.2f}s\", flush=True)\n\n                # 4) Streaming batches -> to_sql\n                t_stream = time.time()\n                for record_batch in dataset.to_batches(batch_size=batch_size):\n                    batch_idx += 1\n                    df_chunk = record_batch.to_pandas()\n\n                    df_chunk[\"ingest_ts\"] = datetime.utcnow()\n                    df_chunk[\"source_month\"] = ym\n                    df_chunk[\"service_type\"] = st\n\n                    df_chunk = align_to_target_schema(df_chunk)\n\n                    df_chunk.to_sql(\n                        name=\"trips_raw\",\n                        con=conn,\n                        schema=\"bronze\",\n                        if_exists=\"append\",\n                        index=False,\n                        method=\"multi\",\n                        chunksize=chunksize\n                    )\n\n                    total_rows += len(df_chunk)\n\n                    del df_chunk\n                    gc.collect()\n\n                    if log_every_batches > 0 and batch_idx % log_every_batches == 0:\n                        print(f\"[JOB {i}] PROGRESS | batches={batch_idx} | rows_loaded={total_rows} | elapsed={time.time()-t_stream:.1f}s\", flush=True)\n\n                upsert_coverage(conn, ym, st, \"loaded\", total_rows)\n\n            ok += 1\n            print(f\"[JOB {i}] DONE OK \u2705 | batches={batch_idx} | rows_loaded={total_rows} | time={time.time()-t_job:.2f}s\", flush=True)\n\n        except Exception as e:\n            failed += 1\n            print(f\"[JOB {i}] FAILED DB load \u274c | {type(e).__name__}: {e}\", flush=True)\n            with engine.begin() as conn:\n                upsert_coverage(conn, ym, st, \"failed\", None)\n\n        finally:\n            # liberar dataset + limpiar parquet local\n            try:\n                del dataset\n            except Exception:\n                pass\n            gc.collect()\n\n            try:\n                if os.path.exists(local_path):\n                    os.remove(local_path)\n                    print(f\"[JOB {i}] Cleaned local file: {local_path}\", flush=True)\n            except Exception as e:\n                print(f\"[JOB {i}] WARN no pude borrar local file | {e}\", flush=True)\n\n        print(f\"[GLOBAL] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed}\", flush=True)\n\n    total_s = time.time() - t_all\n    print(\"\\n\" + \"=\" * 118, flush=True)\n    print(\"[DONE] INGEST FINALIZADO (STREAMING + LOCAL DOWNLOAD)\", flush=True)\n    print(f\"[SUMMARY] ok={ok} | skipped={skipped} | pending={pending} | missing={missing} | failed={failed} | total_jobs={total}\", flush=True)\n    print(f\"[SUMMARY] total_time={(total_s/60):.2f} min\", flush=True)\n    print(\"=\" * 118, flush=True)\n\n    return {\n        \"total\": total,\n        \"ok\": ok,\n        \"skipped\": skipped,\n        \"pending\": pending,\n        \"missing\": missing,\n        \"failed\": failed\n    }\n\n", "file_path": "data_exporters/data_exporter_taxi.py", "language": "python", "type": "data_exporter", "uuid": "data_exporter_taxi"}, "data_exporters/exporter_taxi_zones.py:data_exporter:python:exporter taxi zones": {"content": "import psycopg2\nfrom psycopg2.extras import execute_values\n\nfrom mage_ai.data_preparation.shared.secrets import get_secret_value\n\nif 'data_exporter' not in globals():\n    from mage_ai.data_preparation.decorators import data_exporter\n\n\ndef _secret(name: str, default=None):\n    \"\"\"\n    Lee Mage Secrets; si no existe, usa default.\n    \"\"\"\n    val = get_secret_value(name)\n    return val if val not in (None, \"\") else default\n\n\ndef _get_conn():\n    host = _secret(\"POSTGRES_HOST\", \"warehouse\")\n    port = int(_secret(\"POSTGRES_PORT\", \"5432\"))\n    dbname = _secret(\"POSTGRES_DB\")\n    user = _secret(\"POSTGRES_USER\")\n    password = _secret(\"POSTGRES_PASSWORD\")\n\n    missing = [k for k, v in {\n        \"POSTGRES_DB\": dbname,\n        \"POSTGRES_USER\": user,\n        \"POSTGRES_PASSWORD\": password,\n    }.items() if not v]\n    if missing:\n        raise ValueError(\n            f\"Missing Mage Secrets for Postgres connection: {missing}. \"\n            f\"Go to Mage UI -> Secrets and create them.\"\n        )\n\n    return psycopg2.connect(\n        host=host,\n        port=port,\n        dbname=dbname,\n        user=user,\n        password=password,\n    )\n\n\n@data_exporter\ndef export_data(data, *args, **kwargs):\n    \"\"\"\n    Exporta Taxi Zone Lookup a Postgres (bronze):\n      - Crea schema bronze si no existe\n      - Crea tabla bronze.taxi_zone_lookup si no existe\n      - TRUNCATE (idempotente)\n      - INSERT masivo (r\u00e1pido)\n    \"\"\"\n    if data is None:\n        raise ValueError(\"No data received from upstream block.\")\n    if not isinstance(data, list):\n        raise TypeError(f\"Expected 'data' to be a list[dict], got: {type(data)}\")\n    if len(data) > 0 and not isinstance(data[0], dict):\n        raise TypeError(\"Expected 'data' as list[dict] rows.\")\n\n    conn = _get_conn()\n    try:\n        with conn.cursor() as cur:\n            # 1) Schema + table\n            cur.execute(\"CREATE SCHEMA IF NOT EXISTS bronze;\")\n            cur.execute(\"\"\"\n                CREATE TABLE IF NOT EXISTS bronze.taxi_zone_lookup (\n                    location_id   INTEGER PRIMARY KEY,\n                    borough       TEXT,\n                    zone          TEXT,\n                    service_zone  TEXT,\n                    ingest_ts     TIMESTAMP\n                );\n            \"\"\")\n\n            # 2) Idempotencia\n            cur.execute(\"TRUNCATE TABLE bronze.taxi_zone_lookup;\")\n\n            # 3) Bulk insert\n            rows = [\n                (\n                    r.get(\"location_id\"),\n                    r.get(\"borough\"),\n                    r.get(\"zone\"),\n                    r.get(\"service_zone\"),\n                    r.get(\"ingest_ts\"),\n                )\n                for r in data\n            ]\n\n            execute_values(\n                cur,\n                \"\"\"\n                INSERT INTO bronze.taxi_zone_lookup\n                    (location_id, borough, zone, service_zone, ingest_ts)\n                VALUES %s\n                \"\"\",\n                rows,\n                page_size=1000,\n            )\n\n        conn.commit()\n        return {\"rows_loaded\": len(data), \"table\": \"bronze.taxi_zone_lookup\"}\n    finally:\n        conn.close()\n", "file_path": "data_exporters/exporter_taxi_zones.py", "language": "python", "type": "data_exporter", "uuid": "exporter_taxi_zones"}, "data_loaders/data_loader_taxi.py:data_loader:python:data loader taxi": {"content": "if 'data_loader' not in globals():\n    from mage_ai.data_preparation.decorators import data_loader\nif 'test' not in globals():\n    from mage_ai.data_preparation.decorators import test\n\n\n\n\ndef _parse_years(value):\n    \"\"\"\n    Acepta:\n    - [2024, 2025]\n    - \"2024\"\n    - \"2024,2025\"\n    - \"2022-2025\"\n    - None -> default [2022,2023,2024,2025]\n    \"\"\"\n    if value is None:\n        return [2022, 2023, 2024, 2025]\n\n    # Si trigger manda lista real\n    if isinstance(value, (list, tuple)):\n        out = []\n        for x in value:\n            try:\n                out.append(int(x))\n            except Exception:\n                pass\n        return sorted(list(set(out))) if out else [2022, 2023, 2024, 2025]\n\n    # Si trigger manda string\n    s = str(value).strip()\n    if not s:\n        return [2022, 2023, 2024, 2025]\n\n    # Rango tipo \"2022-2025\"\n    if \"-\" in s and \",\" not in s:\n        a, b = s.split(\"-\", 1)\n        a = int(a.strip())\n        b = int(b.strip())\n        if a > b:\n            a, b = b, a\n        return list(range(a, b + 1))\n\n    # Lista tipo \"2024,2025\"\n    parts = [p.strip() for p in s.split(\",\") if p.strip()]\n    years = [int(p) for p in parts]\n    return sorted(list(set(years)))\n\n\n@data_loader\ndef load_data(*args, **kwargs):\n    years = _parse_years(kwargs.get(\"years\"))\n    services = [\"yellow\", \"green\"]  # fijo (como pediste)\n\n    base_url = \"https://d37ci6vzurychx.cloudfront.net/trip-data\"\n    source_page = \"https://www.nyc.gov/site/tlc/about/tlc-trip-record-data.page\"\n\n    jobs = []\n    for s in services:\n        prefix = f\"{s}_tripdata\"\n        for y in years:\n            for m in range(1, 13):\n                mm = f\"{m:02d}\"\n                jobs.append({\n                    \"year\": y,\n                    \"month\": m,\n                    \"year_month\": f\"{y}-{mm}\",\n                    \"service_type\": s,\n                    \"url_parquet\": f\"{base_url}/{prefix}_{y}-{mm}.parquet\",\n                    \"source_page\": source_page,\n                })\n\n    print(\"=\" * 80)\n    print(\"[DONE] Jobs generados\")\n    print(f\"[INFO] years={years} | services={services}\")\n    print(f\"[INFO] Total jobs: {len(jobs)} (= {len(years)}*12*2)\")\n    print(f\"[INFO] First job: {jobs[0] if jobs else None}\")\n    print(f\"[INFO] Last job : {jobs[-1] if jobs else None}\")\n    print(\"=\" * 80)\n    return jobs\n\n\n", "file_path": "data_loaders/data_loader_taxi.py", "language": "python", "type": "data_loader", "uuid": "data_loader_taxi"}, "data_loaders/data__loader_zones.py:data_loader:python:data  loader zones": {"content": "@data_loader\ndef load_data(*args, **kwargs):\n    import urllib.request\n    import csv\n    import io\n    from datetime import datetime\n\n    url = \"https://d37ci6vzurychx.cloudfront.net/misc/taxi_zone_lookup.csv\"\n\n    with urllib.request.urlopen(url) as response:\n        content = response.read().decode(\"utf-8\")\n\n    reader = csv.DictReader(io.StringIO(content))\n\n    rows = []\n    for r in reader:\n        rows.append({\n            \"location_id\": int(r[\"LocationID\"]),\n            \"borough\": r[\"Borough\"],\n            \"zone\": r[\"Zone\"],\n            \"service_zone\": r[\"service_zone\"],\n            \"ingest_ts\": datetime.utcnow().isoformat()\n        })\n    \n    print(\"TOTAL ROWS:\", len(rows))\n    print(\"SAMPLE:\", rows[:3])\n    return rows\n\n\n    \n\n\n\n", "file_path": "data_loaders/data__loader_zones.py", "language": "python", "type": "data_loader", "uuid": "data__loader_zones"}, "dbts/event_dbt_silver.yaml:dbt:yaml:event dbt silver": {"content": "--select models/silver", "file_path": "dbts/event_dbt_silver.yaml", "language": "yaml", "type": "dbt", "uuid": "event_dbt_silver"}, "dbts/silver_data_process.yaml:dbt:yaml:silver data process": {"content": "command: run\nargs:\n  - \"--select\"\n  - \"silver\"\nproject_dir: \"dbts/silver_transformations\"\nprofiles_dir: \"profiles\"\ntarget: \"dev\"", "file_path": "dbts/silver_data_process.yaml", "language": "yaml", "type": "dbt", "uuid": "silver_data_process"}, "dbts/silver_transformations/README.md:dbt:markdown:silver transformations/README": {"content": "Welcome to your new dbt project!\n\n### Using the starter projec